---
/**
 * Marker wrapper for an editable region. Emits the `data-tina-island`
 * attribute the bridge looks for, with the wrapper element/className taken
 * from the registry entry — so the page-side element matches the server's
 * `IslandConfig.wrapper` automatically.
 *
 * Also emits a tiny in-iframe bootstrap `<script>` so visual editing works
 * on **statically built** pages: the `tina()` middleware only injects the
 * bridge on on-demand-rendered responses, so a prerendered page would
 * otherwise never load it. The script is a no-op for normal visitors
 * (`window.self === window.top`) and only fetches `/_tina/bridge.js` inside
 * the admin iframe; the `window.__tinaBootstrap` guard plus `bridge.init`'s
 * own idempotency keep it harmless when multiple `<TinaIsland>`s render on a
 * page or when the middleware has already injected its own bootstrap. Once a
 * page uses `<TinaIsland>` its production HTML is no longer byte-identical to
 * a Tina-free Astro app — it carries this ~one-line inline script.
 *
 * Usage:
 *
 * ```astro
 * import TinaIsland from '@tinacms/astro/TinaIsland.astro';
 * import { islands } from '../lib/islands';
 *
 * <TinaIsland name="post" wrapper={islands.post.wrapper} params={{ slug }}>
 *   <PostBody data={data} />
 * </TinaIsland>
 * ```
 *
 * `name` must match a key in the `IslandRegistry` you passed to
 * `experimental_createIslandRoute`. `params` is encoded as URL search
 * params and forwarded to the route handler.
 */
import { adminOrigins } from './internal/admin-origin';

interface Props {
  name: string;
  wrapper: { tag: string; className?: string };
  params?: Record<string, string | number>;
}

const { name, wrapper, params } = Astro.props;
const search = params
  ? `?${new URLSearchParams(
      Object.fromEntries(
        Object.entries(params).map(([key, value]) => [key, String(value)])
      )
    ).toString()}`
  : '';
const marker = `/tina-island/${name}${search}`;
const Tag = wrapper.tag as keyof HTMLElementTagNameMap;
const adminOrigin = adminOrigins();
---
<script is:inline type="module" define:vars={{ adminOrigin }}>
  if (window.self !== window.top && !window.__tinaBootstrap) {
    window.__tinaBootstrap = 1;
    const { init, refreshForms } = await import('/_tina/bridge.js');
    init(adminOrigin ? { adminOrigin } : undefined);
    document.addEventListener('astro:page-load', refreshForms);
  }
</script>
<Tag class={wrapper.className} data-tina-island={marker}>
  <slot />
</Tag>
