{
  "name": "@tinacms/tinacms",
  "version": "4.0.0-alpha.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "TinaCMS v4 — plugin-driven, git-native CMS. Single-package rewrite (see ../../../../tinacmsv4 for the architecture spec).",
  "type": "module",
  "repository": {
    "url": "https://github.com/tinacms/tinacms.git",
    "directory": "packages/v4/@tinacms/tinacms"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tinacms-scripts build",
    "dev": "vite playground",
    "types": "tsc",
    "test": "vitest run --passWithNoTests"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/editor/index.ts",
      "default": "./src/editor/index.ts"
    },
    "./preview": {
      "types": "./src/preview/index.ts",
      "default": "./src/preview/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./next": {
      "types": "./src/adapters/next/index.ts",
      "default": "./src/adapters/next/index.ts"
    },
    "./express": {
      "types": "./src/adapters/express/index.ts",
      "default": "./src/adapters/express/index.ts"
    },
    "./astro": {
      "types": "./src/adapters/astro/index.ts",
      "default": "./src/adapters/astro/index.ts"
    },
    "./hono": {
      "types": "./src/adapters/hono/index.ts",
      "default": "./src/adapters/hono/index.ts"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "react-hook-form": "^7.80.0",
    "zod": "catalog:",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tinacms/scripts": "workspace:*",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
