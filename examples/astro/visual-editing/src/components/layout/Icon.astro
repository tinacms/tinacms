---
import { cn } from '../../lib/utils';

interface Props {
  data: {
    name?: string;
    color?: string;
    style?: 'float' | 'circle';
    size?: 'xs' | 'small' | 'medium' | 'large' | 'xl';
  };
  class?: string;
}

const { data, class: className } = Astro.props;

const sizeClass: Record<string, string> = {
  xs: 'w-6 h-6',
  small: 'w-8 h-8',
  medium: 'w-12 h-12',
  large: 'w-14 h-14',
  xl: 'w-16 h-16',
};

const colorClass: Record<string, string> = {
  primary: 'text-theme-500',
  blue: 'text-blue-500',
  teal: 'text-teal-500',
  green: 'text-green-500',
  red: 'text-red-500',
  pink: 'text-pink-500',
  purple: 'text-purple-500',
  orange: 'text-orange-500',
  yellow: 'text-yellow-500',
  white: 'text-white',
};

const styleClass =
  data.style === 'circle'
    ? 'rounded-full bg-current/10 p-3 inline-flex items-center justify-center'
    : 'inline-flex items-center';
const size = sizeClass[data.size ?? 'medium'] ?? sizeClass.medium;
const color = colorClass[data.color ?? 'primary'] ?? colorClass.primary;

const label = data.name ?? '?';
---
<span class={cn(styleClass, color, className)} aria-label={label}>
  <svg viewBox="0 0 24 24" fill="currentColor" class={size}>
    {data.name === 'Tina' ? (
      <path d="M12 2c-1 0-1.9.4-2.6 1.1L4.7 7.7c-.5.5-.5 1.4 0 1.9l1.6 1.6V18c0 .6.4 1 1 1h9.4c.6 0 1-.4 1-1v-6.8l1.6-1.6c.5-.5.5-1.4 0-1.9l-4.7-4.6C13.9 2.4 13 2 12 2z"/>
    ) : data.name === 'BiLayer' ? (
      <path d="M12 2 2 7l10 5 10-5-10-5zm0 12L2 9v6l10 5 10-5V9l-10 5z"/>
    ) : data.name === 'BiSearchAlt2' ? (
      <path d="M11 4a7 7 0 1 0 4.2 12.6l4.6 4.6 1.4-1.4-4.6-4.6A7 7 0 0 0 11 4zm0 2a5 5 0 1 1 0 10 5 5 0 0 1 0-10z"/>
    ) : data.name === 'BiTerminal' ? (
      <path d="M2 4h20v16H2V4zm2 2v12h16V6H4zm3 3 3 3-3 3v-2l1-1-1-1V9zm5 4h6v2h-6v-2z"/>
    ) : (
      <circle cx="12" cy="12" r="6"/>
    )}
  </svg>
</span>
