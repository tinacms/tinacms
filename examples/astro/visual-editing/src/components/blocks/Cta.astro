---
import { tinaField } from '@tinacms/astro/tina-field';
import Actions from '../layout/Actions.astro';
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';

interface Props {
  data: {
    title?: string | null;
    description?: string | null;
    actions?: Array<{
      label?: string | null;
      type?: string | null;
      link?: string | null;
      icon?: boolean | null;
    } | null> | null;
    color?: string | null;
  };
}

const { data } = Astro.props;
---
<Section color={data.color}>
  <Container size="large">
    <div class="text-center">
      <h2 data-tina-field={tinaField(data, 'title')} class="text-balance text-4xl font-semibold lg:text-5xl text-inherit">
        {data.title}
      </h2>
      {data.description && (
        <div data-tina-field={tinaField(data, 'description')} class="mt-4 text-inherit opacity-90 max-w-2xl mx-auto">
          {data.description}
        </div>
      )}
      {data.actions && (
        <div class="mt-12" data-tina-field={tinaField(data, 'actions')}>
          <Actions class="justify-center py-2" parentColor={data.color} actions={data.actions} />
        </div>
      )}
    </div>
  </Container>
</Section>
