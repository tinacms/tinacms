---
import { tinaField } from '@tinacms/bridge/tina-field';
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Actions from '../layout/Actions.astro';

interface Item {
  title?: string | null;
  text?: string | null;
  icon?: { name?: string; color?: string; style?: string } | null;
  actions?: Array<{ label?: string | null; type?: string | null; link?: string | null; icon?: boolean | null } | null> | null;
}

interface Props {
  data: {
    title?: string | null;
    description?: string | null;
    items?: Array<Item | string | null> | null;
    color?: string | null;
  };
}

const { data } = Astro.props;

const normalizedItems: Item[] = (data.items ?? [])
  .filter((item): item is Item | string => item !== null)
  .map((item) => (typeof item === 'string' ? { title: item } : item));

const isSimpleLayout = (data.items ?? []).every((item) => typeof item === 'string');
---
<Section color={data.color}>
  <Container size="large">
    {data.title && (
      <div class="text-center mb-12">
        <h2 data-tina-field={tinaField(data, 'title')} class="text-balance text-3xl font-semibold text-inherit">
          {data.title}
        </h2>
        {data.description && (
          <p data-tina-field={tinaField(data, 'description')} class="mt-4 text-inherit opacity-90">
            {data.description}
          </p>
        )}
      </div>
    )}
    <div class={isSimpleLayout ? 'grid grid-cols-1 md:grid-cols-3 gap-6' : 'flex flex-wrap gap-x-10 gap-y-8 text-left'}>
      {normalizedItems.map((item, idx) => (
        <div
          data-tina-field={tinaField(item as Record<string, unknown>)}
          class={isSimpleLayout ? 'text-center bg-gray-50 dark:bg-gray-800 rounded-lg p-6' : 'flex-1 flex flex-col gap-4 max-w-xl'}
          style={isSimpleLayout ? undefined : 'flex-basis:16rem'}
        >
          {item.title && (
            <h3 class="text-2xl font-semibold title-font">{item.title}</h3>
          )}
          {item.text && (
            <p class="text-base opacity-80 leading-relaxed">{item.text}</p>
          )}
          {item.actions && (
            <Actions actions={item.actions} parentColor={data.color} />
          )}
        </div>
      ))}
    </div>
  </Container>
</Section>
