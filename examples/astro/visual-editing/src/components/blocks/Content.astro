---
import { tinaField } from '@tinacms/bridge/tina-field';
import { cn } from '../../lib/utils';
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import { customComponents } from '../markdown';
import TinaMarkdown from '../rich-text/TinaMarkdown.astro';

interface Props {
  data: {
    body?: unknown;
    color?: string | null;
  };
}

const { data } = Astro.props;
---
<Section color={data.color}>
  <Container
    size="large"
    width="medium"
    class={cn('prose prose-lg', data.color === 'primary' ? 'prose-primary' : 'dark:prose-dark')}
  >
    <div data-tina-field={tinaField(data, 'body')}>
      <TinaMarkdown content={data.body as never} components={customComponents} />
    </div>
  </Container>
</Section>
