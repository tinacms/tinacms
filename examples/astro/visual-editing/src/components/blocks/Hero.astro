---
import TinaMarkdown from '@tinacms/astro/TinaMarkdown.astro';
import { sanitizeImageSrc } from '@tinacms/astro/sanitize';
import { tinaField } from '@tinacms/astro/tina-field';
import type { PageBlocksHero } from '../../../tina/__generated__/types';
import { cn } from '../../lib/utils';
import Actions from '../layout/Actions.astro';
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import { customComponents } from '../markdown';

interface Props {
  data: PageBlocksHero;
}

const { data } = Astro.props;
const imgSrc = sanitizeImageSrc(data.image?.src);
---
<Section color={data.color}>
  <Container size="large" class="grid grid-cols-1 lg:grid-cols-5 gap-14 items-center justify-center">
    <div class="row-start-2 lg:row-start-1 lg:col-span-3 text-center lg:text-left">
      {data.tagline && (
        <h2 data-tina-field={tinaField(data, 'tagline')} class="relative inline-block px-3 py-1 mb-8 text-md font-bold tracking-wide title-font z-20">
          {data.tagline}
        </h2>
      )}
      {data.headline && (
        <h3 data-tina-field={tinaField(data, 'headline')} class="w-full relative mb-10 text-5xl font-extrabold tracking-normal leading-tight title-font">
          <span>{data.headline}</span>
        </h3>
      )}
      {data.text && (
        <div data-tina-field={tinaField(data, 'text')} class={cn('prose prose-lg mx-auto lg:mx-0 mb-10', data.color === 'primary' ? 'prose-primary' : 'dark:prose-dark')}>
          <TinaMarkdown content={data.text} components={customComponents} />
        </div>
      )}
      {data.actions && (
        <div data-tina-field={tinaField(data, 'actions')}>
          <Actions class="justify-center lg:justify-start py-2" parentColor={data.color} actions={data.actions} />
        </div>
      )}
    </div>
    {imgSrc && (
      <div data-tina-field={tinaField(data, 'image')} class="relative row-start-1 lg:col-span-2 flex justify-center">
        <img class="relative z-10 w-full max-w-xs rounded-lg lg:max-w-none h-auto" alt={data.image?.alt ?? ''} src={imgSrc} />
      </div>
    )}
  </Container>
</Section>
