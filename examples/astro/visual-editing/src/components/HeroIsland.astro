---
import { tinaField } from '@tinacms/bridge/tina-field';

interface Props {
  data: { tagline: string | null; headline: string | null } | null;
  islandEndpoint: string;
}

const { data, islandEndpoint } = Astro.props;
---
<section class="hero" data-tina-island={islandEndpoint}>
  <p data-tina-field={tinaField(data, 'tagline')}>{data?.tagline}</p>
  <h1 data-tina-field={tinaField(data, 'headline')}>{data?.headline}</h1>
</section>
