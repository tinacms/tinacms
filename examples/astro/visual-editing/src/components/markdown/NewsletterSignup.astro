---
import TinaMarkdown from '@tinacms/astro/TinaMarkdown.astro';
import type { TinaRichTextContent } from '@tinacms/astro/types';
import { customComponents } from './index';

interface Props {
  placeholder?: string;
  buttonText?: string;
  children?: TinaRichTextContent;
  disclaimer?: TinaRichTextContent;
}

const {
  placeholder = 'Enter your email',
  buttonText = 'Subscribe',
  children,
  disclaimer,
} = Astro.props;
---
<div class="bg-white dark:bg-gray-850" data-tina-newsletter>
  <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    {children && (
      <div class="mb-8">
        <TinaMarkdown content={children} components={customComponents} />
      </div>
    )}
    <form class="sm:flex" data-tina-newsletter-form>
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        name="email-address"
        type="email"
        autocomplete="email"
        required
        placeholder={placeholder}
        class="w-full px-5 py-3 border border-gray-300 shadow-sm placeholder-gray-400 focus:ring-1 focus:ring-theme-500 focus:border-theme-500 sm:max-w-xs rounded dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100"
      />
      <div class="mt-3 rounded shadow sm:mt-0 sm:ml-3 sm:flex-shrink-0">
        <button
          type="submit"
          class="w-full flex items-center justify-center py-3 px-5 border border-transparent text-base font-medium rounded text-white bg-theme-600 hover:bg-theme-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-theme-500 dark:focus:ring-offset-gray-900"
        >
          {buttonText}
        </button>
      </div>
    </form>
    {disclaimer && (
      <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">
        <TinaMarkdown content={disclaimer} components={customComponents} />
      </div>
    )}
  </div>
</div>

<script>
  // Vanilla replacement for the React useState submit handler: clear
  // the input on submit and stop the browser navigating. Wired via
  // delegation so newsletters injected by an edit-mode island refresh
  // pick up the handler without re-running the script.
  document.addEventListener('submit', (event) => {
    const form = event.target as HTMLElement | null;
    if (!form || !(form instanceof HTMLFormElement)) return;
    if (!form.matches('[data-tina-newsletter-form]')) return;
    event.preventDefault();
    const input = form.querySelector<HTMLInputElement>('input[type="email"]');
    if (input) input.value = '';
  });
</script>
