---
import { tinaField } from '@tinacms/bridge/tina-field';

interface Item {
  name: string | null;
  description: string | null;
}

interface Props {
  data: {
    title: string | null;
    items: Item[] | null;
  } | null;
  islandEndpoint: string;
}

const { data, islandEndpoint } = Astro.props;
const items = data?.items ?? [];
---
<section class="features" data-tina-island={islandEndpoint}>
  <h2 data-tina-field={tinaField(data, 'title')}>{data?.title}</h2>
  <ul>
    {items.map((item, index) => (
      <li>
        <strong data-tina-field={tinaField(data, 'items', index)}>{item.name}</strong>
        <span>{item.description}</span>
      </li>
    ))}
  </ul>
</section>
