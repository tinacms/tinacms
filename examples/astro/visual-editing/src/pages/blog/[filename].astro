---
import BlogBody from '../../components/islands/BlogBody.astro';
import Base from '../../layouts/Base.astro';
import { getBlog } from '../../lib/data';

const filename = (Astro.params.filename ?? '').toString();
const blog = await getBlog(filename, Astro.request);
const data = blog.data?.blog as Record<string, unknown> | undefined;
---
<Base
  title={`${(data?.title as string) ?? 'Blog'} | Blog`}
  forms={[{ id: blog.id, query: blog.query, variables: blog.variables, data: blog.data as unknown as object }]}
>
  <article class="max-w-3xl mx-auto px-6 sm:px-8 py-16" data-tina-island={`/tina-island/blog?filename=${encodeURIComponent(filename)}`}>
    <BlogBody data={data} />
  </article>
</Base>
