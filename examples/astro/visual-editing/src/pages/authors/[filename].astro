---
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import AuthorBody from '../../components/islands/AuthorBody.astro';
import Base from '../../layouts/Base.astro';
import { getAuthor } from '../../lib/data';
import { islands } from '../../lib/islands';

const filename = (Astro.params.filename ?? '').toString();
const author = await getAuthor(filename);
if (!author.data?.author) {
  return new Response('Not Found', { status: 404 });
}
const data = author.data.author;
---
<Base title={`${data.name} | Authors`}>
<TinaIsland name="author" wrapper={islands.author.wrapper} params={{ filename }}>
    <AuthorBody data={data} />
  </TinaIsland>
</Base>
