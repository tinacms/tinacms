---
import AuthorBody from '../../components/islands/AuthorBody.astro';
import Base from '../../layouts/Base.astro';
import { getAuthor } from '../../lib/data';

const filename = (Astro.params.filename ?? '').toString();
const author = await getAuthor(filename, Astro.request);
const data = author.data?.author as Record<string, unknown> | undefined;
---
<Base
  title={`${(data?.name as string) ?? 'Author'} | Authors`}
  forms={[{ id: author.id, query: author.query, variables: author.variables, data: author.data as unknown as object }]}
>
  <section class="max-w-3xl mx-auto px-6 sm:px-8 py-16" data-tina-island={`/tina-island/author?filename=${encodeURIComponent(filename)}`}>
    <AuthorBody data={data} />
  </section>
</Base>
