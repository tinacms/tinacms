---
import Blocks from '../components/blocks/Blocks.astro';
import Base from '../layouts/Base.astro';
import { getPage } from '../lib/data';

const segments = (Astro.params.urlSegments ?? '').toString();
const slug = segments || 'home';
const page = await getPage(slug, Astro.request);
---
<Base
  title="TinaCMS Astro Visual Editing"
  forms={[{ id: page.id, query: page.query, variables: page.variables, data: page.data as unknown as object }]}
>
  <div data-tina-island={`/tina-island/page?slug=${encodeURIComponent(slug)}`}>
    <Blocks blocks={(page.data?.page?.blocks ?? []) as Array<Record<string, unknown> | null>} />
  </div>
</Base>
