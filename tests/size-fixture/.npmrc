# Points the fixture install at the throwaway verdaccio registry started by
# scripts/size-baseline.mjs. The dummy _authToken satisfies npm for the
# anonymous-publish registry; verdaccio uplinks everything it doesn't hold
# locally (astro, react, …) to registry.npmjs.org.
# In --registry-mode=real the harness passes `--registry=https://registry.npmjs.org/`
# on the CLI, which overrides the line below.
registry=http://localhost:4873/
//localhost:4873/:_authToken=size-baseline-anon
audit=false
fund=false
